{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hermes Studio",
  "version": "0.1.0",
  "identifier": "com.hermesstudio.desktop",
  "build": {
    "beforeDevCommand": "./scripts/desktop-dev-services.sh",
    "beforeBuildCommand": "./scripts/desktop-build.sh",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Hermes Studio",
        "width": 1180,
        "height": 820,
        "minWidth": 940,
        "minHeight": 680,
        "resizable": true,
        "backgroundThrottling": "disabled"
      },
      {
        "label": "voice-hud",
        "url": "index.html?voice-hud=1",
        "title": "Hermes Voice",
        "width": 88,
        "height": 88,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "closable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "skipTaskbar": true,
        "focus": false,
        "focusable": false,
        "visible": false,
        "backgroundThrottling": "disabled"
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "category": "Productivity",
    "resources": ["bin/hermes-studio-backend-*"],
    "shortDescription": "Native control center for Hermes Agent",
    "longDescription": "Hermes Studio configures Hermes Agent for desktop, voice, and phone control."
  }
}
