{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hermes Studio",
  "version": "0.1.0",
  "identifier": "com.hermesstudio.app",
  "build": {
    "beforeDevCommand": "./scripts/desktop-dev-services.sh",
    "beforeBuildCommand": "cd frontend && npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Hermes Studio",
        "width": 1180,
        "height": 820,
        "minWidth": 940,
        "minHeight": 680,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "category": "Productivity",
    "shortDescription": "Native control center for Hermes Agent",
    "longDescription": "Hermes Studio configures Hermes Agent for desktop, voice, and phone control."
  }
}
